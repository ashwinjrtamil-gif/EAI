# GEMINI_API_KEY: Primary Gemini key (Platform injected).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GEMINI_API_KEY_BACKUP: Secondary Gemini key for failover.
VITE_GEMINI_API_KEY_BACKUP="MY_BACKUP_GEMINI_API_KEY"

# GROQ_API_KEY: Groq key for speed layer and final failover.
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
