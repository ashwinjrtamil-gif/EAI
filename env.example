# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_API_KEY_SECONDARY: Optional secondary key for failover.
GEMINI_API_KEY_SECONDARY="MY_SECONDARY_GEMINI_API_KEY"

# GROQ_API_KEY: Required for Groq Llama 3 failover.
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
